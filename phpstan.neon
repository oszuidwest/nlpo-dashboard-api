parameters:
    level: max
    paths:
        - nlpo-dashboard-api.php
        - includes/
    excludePaths:
        - vendor/
    treatPhpDocTypesAsCertain: false
    ignoreErrors:
        # WP_Query::$posts is array<int|WP_Post>; without 'fields' set
        # the runtime is always WP_Post[] but phpstan can't narrow.
        -
            message: '#Method NLPO_REST_Controller::get_posts\(\) should return array<WP_Post> but returns array<int\|WP_Post>#'
            paths:
                - includes/class-nlpo-rest-controller.php
